#!/bin/bash
# MacArthur HAT setup for VenusOS
# Compatible with SetupHelper by Kevin Windrem
# https://github.com/kwindrem/SetupHelper
#
# Installs/removes:
#   • macarthur-can.dtbo  – MCP2515 CAN controller on SPI0 CE0 (NMEA2000)
#   • macarthur-gpio.dtbo – GPIO21 shutdown-request input & GPIO26 DCDC_EN output
#   • /etc/udev/rules.d/42-macarthur.rules – brings up can0 at 250 kbps
#   • MacArthurShutdown service – holds GPIO26 HIGH, drives LOW on shutdown
#   • /u-boot/config.txt  – dtoverlay entries for the above overlays

#### include SetupHelper resources ####
source "/data/SetupHelper/HelperResources/IncludeHelpers"
#### end SetupHelper resources ####

# ─────────────────────────────────────────────────────────────────────────────
# Helpers: locate boot files (path differs between VenusOS versions)
# ─────────────────────────────────────────────────────────────────────────────

_find_config_file() {
    if [ -f /u-boot/config.txt ]; then
        echo /u-boot/config.txt
    elif [ -f /boot/config.txt ]; then
        echo /boot/config.txt
    else
        echo /u-boot/config.txt   # will be reported as missing
    fi
}

_find_overlay_dir() {
    if [ -d /u-boot/overlays ]; then
        echo /u-boot/overlays
    elif [ -d /boot/overlays ]; then
        echo /boot/overlays
    else
        echo /u-boot/overlays   # will be reported as missing
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Overlay installation
# Pre-compiled .dtbo binaries are shipped with the package (same approach as
# VeCanSetup). No on-device compiler required.
# ─────────────────────────────────────────────────────────────────────────────

# installOverlay <name>
#   Copies overlays/<name>.dtbo → <overlayDir>/<name>.dtbo.
#   Returns 0 on success, 1 on failure.
installOverlay() {
    local name="$1"
    local overlayDir
    overlayDir="$(_find_overlay_dir)"
    local src="$scriptDir/overlays/${name}.dtbo"
    local dst="${overlayDir}/${name}.dtbo"

    if [ ! -f "$src" ]; then
        logMessage "ERROR: pre-compiled overlay not found: $src"
        return 1
    fi
    if [ ! -d "$overlayDir" ]; then
        logMessage "ERROR: overlay directory not found: $overlayDir"
        return 1
    fi

    updateActiveFile "$src" "$dst"
    logMessage "Installed overlay: $dst"
    return 0
}

removeOverlay() {
    local name="$1"
    local overlayDir
    overlayDir="$(_find_overlay_dir)"
    local dst="${overlayDir}/${name}.dtbo"
    if [ -f "$dst" ]; then
        rm -f "$dst"
        logMessage "Removed overlay: $dst"
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# /u-boot/config.txt management
# ─────────────────────────────────────────────────────────────────────────────

MARKER_BEGIN="# begin MacArthurVenusSetup"
MARKER_END="# end MacArthurVenusSetup"

addConfigBlock() {
    local configFile
    configFile="$(_find_config_file)"
    if [ ! -f "$configFile" ]; then
        logMessage "ERROR: boot config file not found: $configFile"
        return 1
    fi

    # Idempotent: remove existing block first
    removeConfigBlock

    cat >> "$configFile" << EOF

$MARKER_BEGIN
# MacArthur HAT – MCP2518FD NMEA2000 CAN controller
# SPI0 CE1 (GPIO7), 20 MHz oscillator, IRQ on GPIO25, 10 MHz SPI
dtparam=spi=on
dtoverlay=macarthur-can
# MacArthur HAT – GPIO26 DCDC_EN output and GPIO21 shutdown-request input
dtoverlay=macarthur-gpio
$MARKER_END
EOF
    logMessage "Added overlay config to $configFile"
    return 0
}

removeConfigBlock() {
    local configFile
    configFile="$(_find_config_file)"
    if [ ! -f "$configFile" ]; then
        return 0
    fi
    # Remove properly-marked blocks (begin … end)
    sed -i "/$MARKER_BEGIN/,/$MARKER_END/d" "$configFile"
    # Also remove any orphaned blocks that start with the HAT comment header
    # but are missing their begin marker (left by earlier package versions)
    sed -i "/# MacArthur HAT/,/$MARKER_END/d" "$configFile"
    # Remove any stray end markers left behind
    sed -i "/$MARKER_END/d" "$configFile"
    logMessage "Removed overlay config from $configFile"
}

# ─────────────────────────────────────────────────────────────────────────────
# udev rules
# ─────────────────────────────────────────────────────────────────────────────

installUdevRules() {
    cp "$scriptDir/udev/42-macarthur.rules" /etc/udev/rules.d/
    udevadm control --reload-rules 2>/dev/null || true
    logMessage "Installed udev rules: /etc/udev/rules.d/42-macarthur.rules"
}

removeUdevRules() {
    rm -f /etc/udev/rules.d/42-macarthur.rules
    udevadm control --reload-rules 2>/dev/null || true
    logMessage "Removed udev rules"
}

# ─────────────────────────────────────────────────────────────────────────────
# Service run script – embed the correct absolute path at install time
# ─────────────────────────────────────────────────────────────────────────────

updateServiceRunScript() {
    local runScript="$scriptDir/services/MacArthurShutdown/run"
    cat > "$runScript" << EOF
#!/bin/sh
# MacArthur HAT – Shutdown Monitor service (generated by setup)
exec /usr/bin/python3 "$scriptDir/src/shutdown_monitor.py"
EOF
    chmod +x "$runScript"
    chmod +x "$scriptDir/services/MacArthurShutdown/log/run"
    chmod +x "$scriptDir/src/shutdown_monitor.py"
    logMessage "Updated service run script with path: $scriptDir/src/shutdown_monitor.py"

    local n2kScript="$scriptDir/services/MacArthurN2K/run"
    sed -i "s|SCRIPT_PATH_PH|$scriptDir/src/dbus_n2k.py|" "$n2kScript"
    chmod +x "$n2kScript"
    chmod +x "$scriptDir/services/MacArthurN2K/log/run"
    chmod +x "$scriptDir/src/dbus_n2k.py"
    logMessage "Updated N2K service run script with path: $scriptDir/src/dbus_n2k.py"
}

# ─────────────────────────────────────────────────────────────────────────────
# Interactive prompt (scriptAction == NONE)
# ─────────────────────────────────────────────────────────────────────────────

if [ "$scriptAction" == "NONE" ]; then
    echo ""
    echo "MacArthur HAT Setup for VenusOS"
    echo "================================"
    echo ""
    echo "This package configures the MacArthur navigation HAT:"
    echo "  • MCP2518FD CAN bus (NMEA 2000) on SPI0 CE1 / GPIO25 IRQ"
    echo "  • GPIO26 (DCDC_EN) – held HIGH to keep HAT DC-DC enabled"
    echo "  • GPIO21 (SHUTDOWN_REQ) – graceful shutdown trigger"
    echo "  • Shutdown monitor service"
    echo ""
    echo "Optional: NMEA 2000 dbus bridge"
    echo "  If the CAN transceiver cannot transmit (TX path issue), vecan-dbus"
    echo "  cannot complete address claiming and will not show NMEA 2000 devices."
    echo "  The N2K dbus bridge bypasses this by reading raw frames in listen-only"
    echo "  mode and publishing directly to dbus.  Fuel tank, engine, etc. will"
    echo "  appear in VenusOS without any CAN bus transmission."
    echo ""
    if [ -f "$scriptDir/services/MacArthurN2K/down" ]; then
        echo "  N2K dbus bridge: DISABLED (down file present)"
    else
        echo "  N2K dbus bridge: ENABLED"
    fi
    echo ""
    yesNoPrompt "Enable NMEA 2000 dbus bridge (workaround for CAN TX issues)? "
    if $yesResponse ; then
        rm -f "$scriptDir/services/MacArthurN2K/down"
        echo "  → N2K bridge ENABLED"
    else
        touch "$scriptDir/services/MacArthurN2K/down"
        echo "  → N2K bridge DISABLED"
    fi
    echo ""
    echo "A reboot is required for overlay changes to take effect."
    echo ""
    standardActionPrompt
fi

# ─────────────────────────────────────────────────────────────────────────────
# INSTALL
# ─────────────────────────────────────────────────────────────────────────────

if [ "$scriptAction" == "INSTALL" ]; then
    logMessage "MacArthur HAT: starting installation from $scriptDir"

    updateRootToReadWrite

    # Verify we are on a Raspberry Pi with the expected overlay directory
    overlayDir="$(_find_overlay_dir)"
    if [ ! -d "$overlayDir" ]; then
        logMessage "ERROR: overlay directory $overlayDir not found – is this a Raspberry Pi running VenusOS?"
        setInstallFailed
        exit
    fi

    # Compile and install device-tree overlays
    installOverlay "macarthur-can"  || { setInstallFailed; exit; }
    installOverlay "macarthur-gpio" || { setInstallFailed; exit; }

    # Add dtoverlay entries to boot config
    addConfigBlock || { setInstallFailed; exit; }

    # Install udev rule for CAN interface bringup
    installUdevRules

    # Regenerate the service run scripts with the correct absolute path
    updateServiceRunScript

    # Log N2K bridge state
    if [ -f "$scriptDir/services/MacArthurN2K/down" ]; then
        logMessage "N2K dbus bridge: disabled (down file present – run setup to enable)"
    else
        logMessage "N2K dbus bridge: enabled"
    fi

    logMessage "MacArthur HAT installation complete – reboot required"
    rebootNeeded=true
fi

# ─────────────────────────────────────────────────────────────────────────────
# UNINSTALL
# ─────────────────────────────────────────────────────────────────────────────

if [ "$scriptAction" == "UNINSTALL" ]; then
    logMessage "MacArthur HAT: starting uninstall"

    updateRootToReadWrite

    removeConfigBlock
    removeOverlay "macarthur-can"
    removeOverlay "macarthur-gpio"
    removeUdevRules

    logMessage "MacArthur HAT uninstall complete – reboot required for overlay removal"
    rebootNeeded=true
fi

# ─────────────────────────────────────────────────────────────────────────────
# Finalise – installs/removes the MacArthurShutdown service and exits
# ─────────────────────────────────────────────────────────────────────────────
endScript INSTALL_SERVICES
